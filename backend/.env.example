# Database
DATABASE_URL=postgresql://username@localhost/jobtracker

# JWT Authentication (run setup.py to generate)
JWT_SECRET_KEY=your-secret-key-here
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Encryption for ATS credentials (run setup.py to generate)
ENCRYPTION_KEY=your-encryption-key-here

# Application
ENVIRONMENT=development
DEBUG=True
API_TITLE=Job Tracker API
API_VERSION=1.0.0

# CORS (comma-separated origins)
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ATS API Keys (optional)
GREENHOUSE_API_KEY=
WORKDAY_CLIENT_ID=
WORKDAY_CLIENT_SECRET=

# Email (optional)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
